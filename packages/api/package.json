{
  "name": "@packing-list/api",
  "version": "0.0.1",
  "scripts": {
    "build": "tsc --build",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "db:test": "ts-node -r dotenv/config src/scripts/testDb.ts dotenv_config_path=.env.local"
  },
  "dependencies": {
    "@packing-list/shared": "*",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-jwt": "^8.5.1",
    "helmet": "^8.2.0",
    "jwks-rsa": "^4.0.1",
    "morgan": "^1.11.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-jwt": "^6.0.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "ts-node-dev": "^2.0.0"
  }
}
